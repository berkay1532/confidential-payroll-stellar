# Privacy-friendly analytics (Plausible). Leave unset to disable the script entirely.
# Set to your deployed domain once live, e.g. confidential-payroll.vercel.app
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional feedback POST endpoint (Formspree / Tally webhook). If unset, the feedback
# widget falls back to a mailto link.
NEXT_PUBLIC_FEEDBACK_ENDPOINT=
